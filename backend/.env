# 服务端配置
# 版本号
APP_VERSION=1.0.0

# 项目名
PROJECT_NAME="blank_tool_server"

# 日志级别: DEBUG, INFO, WARNING, ERROR
BT_LOG_LEVEL=DEBUG

# Python路径
BT_PYTHON_BIN="../runtime/python/python.exe"

# Java路径
BT_JAVA_BIN="../runtime/jre/bin/java.exe"

# 缓存目录
BT_CACHE_DIR="../cache"

# 输出目录
BT_OUTPUT_DIR="../output"
{
  "name": "blank_tool",
  "version": "1.0.1",
  "main": "dist/main/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "lint": "vue-tsc --noEmit --pretty false",
    "typecheck": "vue-tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:report": "vitest run --reporter=html --outputFile=tests/reports/index.html",
    "check": "npm run lint && npm run typecheck && npm run test",
    "build": "vite build && electron-builder",
    "build:win": "vite build && electron-builder --win",
    "build:mac": "vite build && electron-builder --mac",
    "build:linux": "vite build && electron-builder --linux",
    "dist": "npm run build"
  },
  "keywords": [
    "electron",
    "desktop",
    "app",
    "python"
  ],
  "author": "cyanrain",
  "license": "ISC",
  "description": "一个基于 Electron+Vue3 的桌面应用程序，集成 Android 常用开发工具",
  "build": {
    "appId": "com.cyanrain.blank-tool",
    "productName": "Blank Tool",
    "directories": {
      "output": "build"
    },
    "files": [
      "dist/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "backend",
        "to": "backend"
      },
      {
        "from": "runtime",
        "to": "runtime"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "src/main/assets/images/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/electron": "^1.4.38",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.7",
    "@vitest/ui": "^4.1.7",
    "@vue/test-utils": "^2.4.10",
    "concurrently": "^9.2.1",
    "electron": "^38.3.0",
    "electron-builder": "^26.0.12",
    "express": "^5.1.0",
    "happy-dom": "^20.9.0",
    "typescript": "^5.9.3",
    "vite-plugin-electron": "^0.29.1",
    "vite-plugin-electron-renderer": "^0.14.6",
    "vitest": "^4.1.7",
    "vue-tsc": "^3.2.5",
    "wait-on": "^9.0.1"
  },
  "dependencies": {
    "@vitejs/plugin-vue": "^5.2.4",
    "electron-log": "^5.4.3",
    "electron-store": "^11.0.2",
    "pinia": "^3.0.3",
    "vite": "^6.4.1",
    "vue": "^3.2.25",
    "vue-router": "^4.6.3"
  }
}
